#!/usr/bin/env bash
set -euo pipefail

REAL_HOME="${HOME:?HOME is required}"
APP_ID="codex-desktop-ollama"
OPT_ROOT="${REAL_HOME}/.local/opt/${APP_ID}"
APP_DIR="${OPT_ROOT}/codex-app"

find_working_codex_cli() {
    local candidate

    for candidate in \
        "${REAL_HOME}/.nvm/versions/node"/*/bin/codex \
        "${REAL_HOME}/.local/bin/codex" \
        "$(command -v codex 2>/dev/null || true)" \
        /usr/local/bin/codex; do
        [ -n "$candidate" ] || continue
        [ -x "$candidate" ] || continue
        if PATH="$(dirname "$candidate"):${PATH:-}" "$candidate" --version >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

configure_input_method_environment() {
    command -v ibus >/dev/null 2>&1 || return 0

    export GTK_IM_MODULE="${GTK_IM_MODULE:-ibus}"
    export QT_IM_MODULE="${QT_IM_MODULE:-ibus}"
    export XMODIFIERS="${XMODIFIERS:-@im=ibus}"

    if [ -z "${IBUS_ADDRESS:-}" ]; then
        local ibus_address
        ibus_address="$(HOME="$REAL_HOME" XDG_CONFIG_HOME="${REAL_HOME}/.config" ibus address 2>/dev/null || true)"
        if [ -n "$ibus_address" ]; then
            export IBUS_ADDRESS="$ibus_address"
        fi
    fi
}

start_reasoning_proxy() {
    local proxy_script="${REAL_HOME}/.local/share/codex-desktop-ollama/ollama-reasoning-proxy.py"
    local proxy_port="${CODEX_OLLAMA_REASONING_PROXY_PORT:-11435}"
    local upstream="${CODEX_OLLAMA_UPSTREAM:-http://127.0.0.1:11434}"
    local cache_dir="${XDG_CACHE_HOME:-${REAL_HOME}/.cache}/codex-desktop-ollama"
    local state_dir="${XDG_STATE_HOME:-${REAL_HOME}/.local/state}/codex-desktop-ollama"
    local log_file="$cache_dir/ollama-reasoning-proxy.log"
    local pid_file="$state_dir/ollama-reasoning-proxy.pid"

    [ -f "$proxy_script" ] || return 0
    command -v python3 >/dev/null 2>&1 || return 0

    export CODEX_OLLAMA_REASONING_PROXY_PORT="$proxy_port"
    export CODEX_OLLAMA_UPSTREAM="$upstream"

    if python3 - "$proxy_port" <<'PY' >/dev/null 2>&1
import sys
import urllib.request

port = sys.argv[1]
urllib.request.urlopen(
    f"http://127.0.0.1:{port}/__codex_ollama_reasoning_proxy_health",
    timeout=0.5,
).read()
PY
    then
        return 0
    fi

    mkdir -p "$cache_dir" "$state_dir"
    if command -v setsid >/dev/null 2>&1; then
        setsid -f python3 "$proxy_script" \
            --host 127.0.0.1 \
            --port "$proxy_port" \
            --upstream "$upstream" \
            >>"$log_file" 2>&1
    else
        nohup python3 "$proxy_script" \
            --host 127.0.0.1 \
            --port "$proxy_port" \
            --upstream "$upstream" \
            >>"$log_file" 2>&1 &
    fi

    sleep 0.2
    pgrep -f "$proxy_script.*--port $proxy_port" | head -n 1 >"$pid_file" || true
}

export CODEX_HOME="${CODEX_HOME:-${REAL_HOME}/.codex-ollama}"
export CODEX_REAL_HOME="${CODEX_REAL_HOME:-$REAL_HOME}"
export CODEX_OLLAMA_PROFILE_HOME="${CODEX_OLLAMA_PROFILE_HOME:-$CODEX_HOME}"
export CODEX_CLI_PATH="${CODEX_CLI_PATH:-$(find_working_codex_cli || true)}"
if [ -n "$CODEX_CLI_PATH" ]; then
    export PATH="$(dirname "$CODEX_CLI_PATH"):${PATH:-}"
fi
export CODEX_XDG_CONFIG_HOME="${CODEX_XDG_CONFIG_HOME:-${REAL_HOME}/.local/state/codex-desktop-ollama/xdg-config}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$CODEX_XDG_CONFIG_HOME}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${REAL_HOME}/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-${REAL_HOME}/.local/state}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-${REAL_HOME}/.local/share}"
export CODEX_WEBVIEW_PORT="${CODEX_WEBVIEW_PORT:-5176}"
export CODEX_MULTI_LAUNCH_PORT_RANGE="${CODEX_MULTI_LAUNCH_PORT_RANGE:-5176-5180}"
export CHROME_DESKTOP="${CHROME_DESKTOP:-codex-desktop-ollama.desktop}"
export BAMF_DESKTOP_FILE_HINT="${BAMF_DESKTOP_FILE_HINT:-${REAL_HOME}/.local/share/applications/codex-desktop-ollama.desktop}"
export CODEX_SKIP_URL_SCHEME_REGISTRATION=1
export CODEX_SKIP_CHROME_NATIVE_HOST_SYNC=1
configure_input_method_environment
export HOME="${CODEX_ISOLATED_HOME:-${REAL_HOME}/.local/state/codex-desktop-ollama/home}"

mkdir -p "$CODEX_HOME" "$CODEX_XDG_CONFIG_HOME" "$HOME"
start_reasoning_proxy

CODEX_HOME_ALIAS="${HOME}/.codex-ollama"
if [ "$CODEX_HOME_ALIAS" != "$CODEX_HOME" ] && [ "$CODEX_HOME" = "${REAL_HOME}/.codex-ollama" ]; then
    if [ -L "$CODEX_HOME_ALIAS" ]; then
        alias_target="$(readlink -f "$CODEX_HOME_ALIAS" 2>/dev/null || true)"
        if [ "$alias_target" != "$CODEX_HOME" ]; then
            ln -sfn "$CODEX_HOME" "$CODEX_HOME_ALIAS"
        fi
    elif [ ! -e "$CODEX_HOME_ALIAS" ]; then
        ln -s "$CODEX_HOME" "$CODEX_HOME_ALIAS"
    fi
fi

exec "${APP_DIR}/start.sh" "$@"
